+app.get('/users/:id/profile', async (req, res) => {
+  const id = parseUserId(req.params.id);
+  if (id === null) {
+    return res.status(400).type('html').send('Invalid user id');
+  }
+  try {
+    const result = await pool.query(
+      'SELECT id, name, email FROM users WHERE id = $1',
+      [id]
+    );
+    if (result.rowCount === 0) {
+      return res.status(404).type('html').send('User not found');
+    }
+    const u = result.rows[0];
+    res.type('html').send(
+      `<!DOCTYPE html><html><body><h1>Profile</h1><p>Name: ${u.name}</p><p>Email: ${u.email}</p></body></html>`
+    );
+  } catch (err) {
+    console.error('GET /users/:id/profile failed:', err);
+    res.status(500).type('html').send('Database error');
+  }
+});
