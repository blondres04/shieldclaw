# GitHub Personal Access Token (needs repo read access)
GITHUB_PAT=ghp_your_token_here

# Target repository and PR number to monitor
TARGET_REPO=owner/repo-name
TARGET_PR=1

# Ollama Configuration
OLLAMA_HOST=http://host.docker.internal:11434

# PostgreSQL
POSTGRES_USER=shieldclaw
POSTGRES_PASSWORD=change_me
POSTGRES_DB=shieldclaw_db

# JWT signing key for the backend (HS256). Must be standard Base64 encoding of raw key bytes;
# after decoding, the key must be at least 256 bits (32 bytes). Generate e.g.:
#   openssl rand -base64 32
JWT_SECRET=

# Single admin user for PoC login (AuthController); change in production
SHIELDCLAW_ADMIN_USERNAME=
SHIELDCLAW_ADMIN_PASSWORD=
